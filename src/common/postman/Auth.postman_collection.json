  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "const { data } = pm.response.json()\r",
              "pm.globals.set(\"accessToken\", data.accessToken)\r",
              "pm.globals.set(\"refreshToken\", data.refreshToken)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"userEmail\": \"e@email.com\",\r\n    \"userPassword\": \"qweasd\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{domain}}/auth/login",
          "host": [
            "{{domain}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
