          "mode": "raw",
          "raw": "{\r\n    \"userEmail\": \"f@email.com\",\r\n    \"userPassword\": \"qweasd\",\r\n    \"userFullname\": \"kepler\",\r\n    \"userType\": \"admin\"\r\n}",
          "options": {
